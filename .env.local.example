# Local packaging overrides. Copy values into .env.local; do not commit .env.local.

# The scripts use the active xcode-select toolchain unless DEVELOPER_DIR is set.
# DEVELOPER_DIR="$HOME/Applications/Xcode-beta.app/Contents/Developer"

# Public builds default to ad-hoc signing with "-".
# ONEMORECAP_CODESIGN_IDENTITY="Apple Development: Your Name (TEAMID)"

# Override this for a personal Developer ID or Apple Development build.
# ONEMORECAP_BUNDLE_IDENTIFIER="com.example.one-more-cap"

# Optional release metadata.
# ONEMORECAP_BUNDLE_SHORT_VERSION="0.1.0"
# ONEMORECAP_BUNDLE_VERSION="1"
# ONEMORECAP_MINIMUM_SYSTEM_VERSION="26.0"

# Optional distribution channel. github includes Sparkle and Apple TV sync;
# appstore excludes Sparkle and Apple TV sync.
# ONEMORECAP_DISTRIBUTION_CHANNEL="github"

# Optional app naming. Keep ONEMORECAP_BUNDLE_IDENTIFIER stable across renames
# if users should continue receiving Sparkle updates.
# ONEMORECAP_APP_NAME="One More Cap"
# ONEMORECAP_APP_BUNDLE_NAME="One More Cap"
# ONEMORECAP_APP_EXECUTABLE_NAME="One More Cap"
# ONEMORECAP_STATUS_ITEM_TITLE="Cap"
# ONEMORECAP_APP_ICON_SOURCE="/path/to/AppIcon.icon"
# ONEMORECAP_MENU_BAR_ICON_SOURCE_DIR="/path/to/menu-bar-icons"

# Optional Sparkle update configuration. The public key and feed URL are safe
# to embed in app bundles. Keep the private key in Keychain or GitHub Secrets.
# ONEMORECAP_SPARKLE_PUBLIC_ED_KEY="base64-public-key"
# ONEMORECAP_SPARKLE_FEED_URL="https://github.com/deemoe404/onemorecap/releases/latest/download/appcast.xml"
# ONEMORECAP_SPARKLE_KEY_ACCOUNT="onemorecap"
# ONEMORECAP_SPARKLE_PRIVATE_KEY_FILE="/path/to/local-private-key"
# ONEMORECAP_SPARKLE_PRIVATE_KEY="private-key-for-CI-only"

# Enable if you later notarize Developer ID builds.
# ONEMORECAP_CODESIGN_HARDENED_RUNTIME=1
# ONEMORECAP_CODESIGN_ENTITLEMENTS="path/to/OneMoreCap.entitlements"
