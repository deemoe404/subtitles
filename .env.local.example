# Local packaging overrides. Copy values into .env.local; do not commit .env.local.

# The scripts use the active xcode-select toolchain unless DEVELOPER_DIR is set.
# DEVELOPER_DIR="$HOME/Applications/Xcode-beta.app/Contents/Developer"

# Public builds default to ad-hoc signing with "-".
# SUBTITLES_CODESIGN_IDENTITY="Apple Development: Your Name (TEAMID)"

# Override this for a personal Developer ID or Apple Development build.
# SUBTITLES_BUNDLE_IDENTIFIER="com.example.one-more-cap"

# Optional release metadata.
# SUBTITLES_BUNDLE_SHORT_VERSION="0.1.0"
# SUBTITLES_BUNDLE_VERSION="1"

# Optional distribution channel. github includes Sparkle and Apple TV sync;
# appstore excludes Sparkle and Apple TV sync.
# SUBTITLES_DISTRIBUTION_CHANNEL="github"

# Optional app naming. Keep SUBTITLES_BUNDLE_IDENTIFIER stable across renames
# if users should continue receiving Sparkle updates.
# SUBTITLES_APP_NAME="One More Cap"
# SUBTITLES_APP_BUNDLE_NAME="One More Cap"
# SUBTITLES_APP_EXECUTABLE_NAME="One More Cap"
# SUBTITLES_STATUS_ITEM_TITLE="Cap"

# Optional Sparkle update configuration. The public key and feed URL are safe
# to embed in app bundles. Keep the private key in Keychain or GitHub Secrets.
# SUBTITLES_SPARKLE_PUBLIC_ED_KEY="base64-public-key"
# SUBTITLES_SPARKLE_FEED_URL="https://github.com/deemoe404/onemoresub/releases/latest/download/appcast.xml"
# SUBTITLES_SPARKLE_KEY_ACCOUNT="subtitles"
# SUBTITLES_SPARKLE_PRIVATE_KEY_FILE="/path/to/local-private-key"
# SUBTITLES_SPARKLE_PRIVATE_KEY="private-key-for-CI-only"

# Enable if you later notarize Developer ID builds.
# SUBTITLES_CODESIGN_HARDENED_RUNTIME=1
# SUBTITLES_CODESIGN_ENTITLEMENTS="path/to/Subtitles.entitlements"
